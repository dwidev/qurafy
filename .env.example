# --------------------
# Application/Auth URL
# --------------------
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-random-secret

# --------------------
# Database (use ONE approach)
# --------------------
# Option A (recommended): direct Postgres URL from Supabase
DATABASE_URL=postgresql://postgres:<password>@db.ppggiucjzuvxdwqwaunu.supabase.co:5432/postgres

# Option B: derived from Supabase project URL + DB password
# NEXT_PUBLIC_SUPABASE_URL=https://ppggiucjzuvxdwqwaunu.supabase.co
# SUPABASE_DB_PASSWORD=<your-db-password>
# Optional overrides for Option B:
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_HOST=db.ppggiucjzuvxdwqwaunu.supabase.co
# SUPABASE_DB_PORT=5432

# --------------------
# Supabase public client vars (frontend only)
# --------------------
NEXT_PUBLIC_SUPABASE_URL=https://ppggiucjzuvxdwqwaunu.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx

# --------------------
# OAuth Providers
# --------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --------------------
# SMTP (Password Reset Email)
# --------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=Qurafy <no-reply@qurafy.io>

# --------------------
# Manual Support / Transfer
# --------------------
SUPPORT_ADMIN_EMAILS=admin@qurafy.io
SUPPORT_CONTACT_EMAIL=support@qurafy.io
SUPPORT_CONTACT_PHONE=+62 812 3456 7890
PLATFORM_BANK_NAME=BCA
PLATFORM_BANK_ACCOUNT_NUMBER=1234567890
PLATFORM_BANK_ACCOUNT_HOLDER=Qurafy
